{
  "name": "dev-toolkit-pro",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:front": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "busybox rm -rf dist",
    "lint": "pnpm run lint:types && pnpm run lint:biome",
    "lint:types": "tsc --noEmit",
    "lint:biome": "biome check .",
    "format": "biome format --write .",
    "check": "biome check .",
    "predeploy": "pnpm install && pnpm run clean && pnpm run lint",
    "deploy": "pnpm build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply dev-toolkit-db --local --yes",
    "db:migrate": "wrangler d1 migrations apply dev-toolkit-db --remote --yes"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@vitejs/plugin-react": "^5.1.4",
    "fflate": "^0.8.2",
    "framer-motion": "^12.35.2",
    "highlight.js": "^11.11.1",
    "hono": "^4.12.5",
    "jsonpath-plus": "^10.4.0",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.577.0",
    "motion": "^12.35.2",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vite": "^7.3.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@cloudflare/workers-types": "^4.20260307.1",
    "@types/highlight.js": "^10.1.0",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "autoprefixer": "^10.4.27",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^6.2.0",
    "wrangler": "^4.71.0"
  }
}
