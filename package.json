{
  "name": "dev-toolkit-pro",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite --port=3000 --host=0.0.0.0\" \"wrangler dev\"",
    "build": "vite build",
    "clean": "busybox rm -rf dist",
    "lint": "tsc --noEmit && biome check .",
    "format": "biome check --write .",
    "predeploy": "pnpm install && pnpm run clean && pnpm run lint",
    "deploy": "pnpm build && wrangler deploy",
    "db": "cross-env CI=true wrangler d1 migrations apply DB --local && cross-env CI=true wrangler d1 migrations apply DB --remote"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "fflate": "^0.8.2",
    "framer-motion": "^12.38.0",
    "highlight.js": "^11.11.1",
    "hono": "^4.12.9",
    "jsonpath-plus": "^10.4.0",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.577.0",
    "motion": "^12.38.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.3",
    "wrangler": "^4.78.0"
  }
}
